{
  "trailingSlash": "auto",
  "mimeTypes": {
    ".docx": "application/vnd.openxmlformats-officedocument.wordprocessingml.document"
  },
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "X-Frame-Options": "DENY",
    "Referrer-Policy": "strict-origin-when-cross-origin"
  },
  "responseOverrides": {
    "404": {
      "rewrite": "/index.html",
      "statusCode": 200
    }
  }
}
